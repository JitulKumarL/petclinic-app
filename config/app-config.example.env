# App configuration - EXAMPLE
# Copy to app-config.env for local use. Git ignore app-config.env.
# For CI: set these as GitHub Actions Variables (or Secrets) - see SETUP.md
#
# Usage: source config/app-config.env (or export manually)

# ECR
AWS_REGION=ap-south-1
ECR_REPOSITORY=petclinic

# GitHub Actions uses secrets for these (not files):
# AWS_ROLE_ARN=arn:aws:iam::ACCOUNT:role/github-actions-ecr
# SONAR_HOST_URL=https://your-sonarqube.example.com
# SONAR_TOKEN=...
